{
  "rules": {
    "profiles": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "public": {
      ".read": true,
      ".write": "auth != null"
    },
    "contacts": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "analytics": {
      "$pushId": {
        ".write": "auth != null",
        ".read": "auth != null && root.child('admins').child(auth.uid).val() === true"
      }
    },
    "admins": {
      ".read": false,
      ".write": false
    },
    ".read": false,
    ".write": false
  }
}
