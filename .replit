modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -- --hostname 0.0.0.0 --port 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 33667
externalPort = 6000

[[ports]]
localPort = 37911
externalPort = 4200

[[ports]]
localPort = 38603
externalPort = 3003

[[ports]]
localPort = 40559
externalPort = 5173

[[ports]]
localPort = 42601
externalPort = 3002

[[ports]]
localPort = 43999
externalPort = 5000

[[ports]]
localPort = 45673
externalPort = 3000

[[ports]]
localPort = 46013
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "start"]
